{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidekick2000",
  "identifier": "com.sidekick2000.app",
  "version": "0.2.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sidekick2000",
        "width": 720,
        "height": 900,
        "resizable": true,
        "minWidth": 600,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Record, transcribe, and summarize meetings locally",
    "longDescription": "Sidekick2000 records local mic and system audio in parallel, transcribes them on-device with whisper.cpp (Metal), and produces structured Markdown notes summarized by Claude or Together.ai. Optional git commit and GitHub issue creation for action items.",
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    }
  }
}
